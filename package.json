{
  "name": "oryqon",
  "version": "0.0.0",
  "private": true,
  "description": "ORYQON — a verified command layer for operating products, campaigns, channels and revenue across the commercial internet.",
  "author": "Frank Asante Van Laarhoven <frankleroyvan@gmail.com>",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @oryqon/web",
    "build": "npm run build --workspace @oryqon/web",
    "start": "npm run start --workspace @oryqon/web",
    "lint": "npm run lint --workspace @oryqon/web",
    "test": "npm run test --workspace @oryqon/control-plane",
    "test:rls": "bash apps/control-plane/db/test-rls.sh",
    "typecheck": "npm run typecheck --workspace @oryqon/control-plane",
    "check:branding": "node scripts/check-branding.mjs",
    "check": "npm run check:branding && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  }
}
